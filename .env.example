# One file for the whole stack: API + SQLite (DATA_DIR) + optional LLM.
# Dev: run `npm run start:all` from repo root — UI (Vite) proxies /api to PORT below.
# No web/.env needed.

# Required: single shared secret for all API calls (Bearer token)
BRAIN_PASSWORD=change-me

PORT=3030

# SQLite + uploads (created automatically). One device / one DATA_DIR: only one
# server process may use it at a time (lock file). Override if stuck: BRAIN_SKIP_LOCK=1
DATA_DIR=./data
# BRAIN_SKIP_LOCK=1

# Optional: OpenAI-compatible chat (Ollama, LM Studio, OpenAI, etc.)
# If unset, /api/chat returns an error unless you only use notes CRUD.
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=
LLM_MODEL=llama3

# RAG: how many text chunks to inject into the prompt
CHAT_CONTEXT_CHUNKS=8

# Optional: same OpenAI-compatible base URL as LLM_BASE_URL — enables semantic rerank of FTS hits
# LLM_EMBEDDING_MODEL=nomic-embed-text
# FTS_CANDIDATE_CHUNKS=48

# Upload limit per file (MB) for documents + ZIP entries
# MAX_UPLOAD_MB=40

# Max size (MB) for full-library restore ZIP (POST /api/management/import/backup)
# BRAIN_MAX_RESTORE_ZIP_MB=512

# Default body for new notes (optional)
# NOTE_TEMPLATE=# Notes\n\n-

# API rate limit (per IP, all /api routes)
# API_RATE_WINDOW_MS=60000
# API_RATE_MAX=300
