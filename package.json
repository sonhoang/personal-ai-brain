{
  "name": "personal-ai-brain",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first personal AI brain — SQLite, local files, simple env password",
  "scripts": {
    "start:all": "npm run dev",
    "dev": "concurrently -n api,ui -c blue,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:web": "npm run dev --prefix web",
    "build": "tsc && npm run build --prefix web",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "axios": "^1.7.0",
    "better-sqlite3": "^11.6.0",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "mammoth": "^1.12.0",
    "multer": "^2.0.0",
    "pdf-parse": "^2.4.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.0.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
